(set-logic QF_UF)
(declare-sort U 0)
(declare-sort V 0)
(declare-fun b (U) V)
(declare-fun p () Bool)
(declare-fun q () Bool)
(declare-fun x () U)
(declare-fun y () U)
(declare-fun z () U)
(assert (! (= y z) :named smtcomp1))
(assert (! (= (ite p x z) (ite p (ite q y z) x)) :named smtcomp2))
(assert (! (not (= (b x) (b y))) :named smtcomp3))
(check-sat)
(get-unsat-core)
(get-interpolants (and smtcomp1 smtcomp2) (and smtcomp3))