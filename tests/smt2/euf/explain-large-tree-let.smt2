(declare-sort ET)
(declare-fun f (ET ET) ET)
(declare-const al ET)
(define-const bl ET (f al al))
(define-const cl ET (f bl bl))
(define-const dl ET (f cl cl))
(declare-const ar ET)
(define-const dldr Bool (= dl (let ((br (f (let ((ar2 ar)) ar2) ar))) (let ((cr (f br (let ((ar br)) ar)))) (f (let ((ar cr)) ar) cr)))))
(check-sat-assuming ((= al ar) (not dldr)))
(get-unsat-assumptions)