sat
(
 (define-fun a () Real 1)
 (define-fun a_bool () Bool true)
 (define-fun al () Bool true)
 (define-fun au () Bool true)
 (define-fun b () Real 0)
 (define-fun b_bool () Bool false)
 (define-fun bl () Bool true)
 (define-fun bu () Bool true)
