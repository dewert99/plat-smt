(set-logic QF_UF)
(declare-sort U 0)
(declare-fun f (U) U)
(declare-fun p () Bool)
(declare-fun q () Bool)
(declare-fun r () Bool)
(declare-fun s () Bool)
(declare-fun v () U)
(declare-fun x () U)
(declare-fun y () U)
(declare-fun y* () U)
(declare-fun z () U)
(assert (! (not (= z (f x))) :named smtcomp1))
(assert (! (not (= y z)) :named smtcomp2))
(assert (! (= (f y) (ite r (ite q y* y) x)) :named smtcomp3))
(assert (! (= z (f (f y))) :named smtcomp4))
(assert (! (= y* y) :named smtcomp5))
(assert (! (=> s r) :named smtcomp6))
(assert (! (= p (or q (not s))) :named smtcomp7))
(check-sat)
(get-interpolants (and smtcomp4 smtcomp5 smtcomp6 smtcomp7) (and smtcomp1 smtcomp2 smtcomp3))
(get-interpolants (and smtcomp1 smtcomp2 smtcomp4 smtcomp6 smtcomp7) (and smtcomp3 smtcomp5))